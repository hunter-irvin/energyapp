# Server runtime
PORT=8000

# Supabase (publishable values can be exposed client-side by server injection)
ENERGYAPP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
ENERGYAPP_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Supabase server-only secret (do not expose in browser)
ENERGYAPP_SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Rates providers (server-only)
# CAISO live adapter does not require credentials.
# ERCOT live adapter requires ERCOT Public API credentials + endpoint configuration.
ENERGYAPP_ERCOT_SUBSCRIPTION_KEY=YOUR_ERCOT_SUBSCRIPTION_KEY
ENERGYAPP_ERCOT_ID_TOKEN=YOUR_ERCOT_ID_TOKEN
# Optional token flow (use when not supplying ENERGYAPP_ERCOT_ID_TOKEN directly):
ENERGYAPP_ERCOT_USERNAME=YOUR_ERCOT_USERNAME
ENERGYAPP_ERCOT_PASSWORD=YOUR_ERCOT_PASSWORD
ENERGYAPP_ERCOT_CLIENT_ID=fec253ea-0d06-4272-a5e6-b478baeecd70
ENERGYAPP_ERCOT_SCOPE=openid fec253ea-0d06-4272-a5e6-b478baeecd70 offline_access
ENERGYAPP_ERCOT_AUTH_URL=https://ercotb2c.b2clogin.com/ercotb2c.onmicrosoft.com/B2C_1_PUBAPI-ROPC-FLOW/oauth2/v2.0/token
ENERGYAPP_ERCOT_API_BASE=https://api.ercot.com
ENERGYAPP_ERCOT_RT_LMP_ENDPOINT=
ENERGYAPP_ERCOT_DA_LMP_ENDPOINT=

# Weather providers (server-only)
ENERGYAPP_NREL_API_KEY=YOUR_NREL_API_KEY
ENERGYAPP_NREL_CONTACT_EMAIL=you@example.com

# Optional runtime flags
ENERGYAPP_ALLOW_INSECURE_OPEN_METEO_TLS=0
ENERGYAPP_ALLOW_INSECURE_NREL_TLS=1
